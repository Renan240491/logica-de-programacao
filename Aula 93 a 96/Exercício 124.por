programa {
  funcao inicio() {
    inteiro vetor [6] = {11,18,25,30,42,55}
    inteiro chave
    
    escreva("Digite o valor que deseja buscar:")
    leia(chave)

    para (inteiro i = 0; i <6; i++){
 
      se(vetor[i]> chave)
      
  {
  escreva("Elemento encontrado na posição:",i)
  pare
      }
    }
  }
}
  


